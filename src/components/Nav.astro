---
const currentPath = Astro.url.pathname;

const programs = [
  {
    slug: 'seminar',
    label: 'Weekly Seminar',
    items: [
      { href: '/seminar/people', label: 'People' },
      { href: '/seminar/projects', label: 'Projects' },
    ],
  },
  {
    slug: 'lab',
    label: 'Summer Lab',
    items: [
      { href: '/lab/people', label: 'People' },
      { href: '/lab/projects', label: 'Projects' },
    ],
  },
  {
    slug: 'moneyball',
    label: 'Moneyball Programs',
    items: [
      { href: '/moneyball', label: 'Home' },
      {
        label: 'Academy',
        section: '/moneyball/academy',
        menu: [
          { href: '/moneyball/academy/people', label: 'People' },
          {
            label: 'Lectures',
            menu: [
              { href: '/moneyball/academy/lecture0', label: 'Lecture 0' },
              { href: '/moneyball/academy/lecture1', label: 'Lecture 1' },
              { href: '/moneyball/academy/lecture2', label: 'Lecture 2' },
              { href: '/moneyball/academy/lecture3', label: 'Lecture 3' },
              { href: '/moneyball/academy/lecture4', label: 'Lecture 4' },
              { href: '/moneyball/academy/lecture5', label: 'Lecture 5' },
              { href: '/moneyball/academy/lecture6', label: 'Lecture 6' },
              { href: '/moneyball/academy/lecture7', label: 'Lecture 7' },
              { href: '/moneyball/academy/lecture8', label: 'Lecture 8' },
            ],
          },
          {
            label: 'Problem Sets',
            menu: [
              { href: '/moneyball/academy/ps0', label: 'Problem Set 0' },
              { href: '/moneyball/academy/ps1', label: 'Problem Set 1' },
              { href: '/moneyball/academy/ps2', label: 'Problem Set 2' },
              { href: '/moneyball/academy/ps3', label: 'Problem Set 3' },
              { href: '/moneyball/academy/ps4', label: 'Problem Set 4' },
              { href: '/moneyball/academy/ps5', label: 'Problem Set 5' },
              { href: '/moneyball/academy/ps6', label: 'Problem Set 6' },
              { href: '/moneyball/academy/ps7', label: 'Problem Set 7' },
              { href: '/moneyball/academy/ps8', label: 'Problem Set 8' },
            ],
          },
        ],
      },
      {
        label: 'Training Camp',
        section: '/moneyball/training-camp',
        menu: [
          { href: '/moneyball/training-camp/people', label: 'People' },
          {
            label: 'Lectures',
            menu: [
              { href: '/moneyball/academy/lecture0', label: 'Lecture 0' },
              { href: '/moneyball/training-camp/lecture1', label: 'Lecture 1' },
              { href: '/moneyball/training-camp/lecture2', label: 'Lecture 2' },
              { href: '/moneyball/training-camp/lecture3', label: 'Lecture 3' },
              { href: '/moneyball/training-camp/lecture4', label: 'Lecture 4' },
              { href: '/moneyball/training-camp/lecture5', label: 'Lecture 5' },
            ],
          },
          {
            label: 'Problem Sets',
            menu: [
              { href: '/moneyball/training-camp/ps1', label: 'Problem Set 1' },
              { href: '/moneyball/training-camp/ps2', label: 'Problem Set 2' },
              { href: '/moneyball/training-camp/ps3', label: 'Problem Set 3' },
            ],
          },
          { href: '/moneyball/training-camp/data-sources', label: 'Other Data' },
        ],
      },
      { href: '/moneyball/projects', label: 'Projects' },
    ],
  },
];

const path = currentPath.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
  const h = href.replace(/\/$/, '') || '/';
  return path === h;
}

function isItemActive(
  item: { href?: string; label?: string; section?: string; menu?: { href?: string; menu?: unknown[] }[] },
  parentSection?: string
): boolean {
  const section = 'section' in item && typeof item.section === 'string' ? item.section : parentSection;
  const inSection = !section || path === section || path.startsWith(section + '/');
  if (!inSection && section) return false;
  if (item.href) return isActive(item.href) && (!section || inSection);
  if (item.menu) {
    return item.menu.some((m) =>
      m.href ? isActive(m.href) && (!section || path.startsWith(section + '/') || path === section) : m.menu && isItemActive(m as { menu: { href?: string }[] }, section)
    );
  }
  return false;
}

function programIsActive(slug: string): boolean {
  return path === `/${slug}` || path.startsWith(`/${slug}/`);
}
---

<header class="border-b border-warm-200 bg-white/80 backdrop-blur-sm sticky top-0 z-50">
  <nav class="mx-auto max-w-5xl px-4 md:px-6 py-3 md:py-4 flex items-center justify-between gap-4">
    <div class="flex items-center gap-6 md:gap-8">
      <a href="/" class="flex items-center gap-2 shrink-0">
        <img src="/images/wharton-logo.png" alt="" class="h-8 w-auto" />
        <span class="text-xl font-semibold text-penn-blue tracking-tight">WSABI</span>
      </a>
      <!-- Desktop nav (hidden on mobile) -->
      <div class="hidden md:flex items-center gap-1">
      {programs.map((program) => (
        <div class="relative group">
          <button
            type="button"
            class:list={[
              'flex items-center gap-1 px-4 py-2 rounded-lg text-sm font-medium transition-colors',
              programIsActive(program.slug) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
            ]}
          >
            {program.label}
            <svg class="h-4 w-4 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute left-0 top-full pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
            <div class="bg-white rounded-lg shadow-lg border border-warm-200 py-1 w-fit min-w-[100px]">
              <div class="py-1">
                {program.items.map((item) =>
                  'menu' in item && item.menu ? (
                    <div class="relative group/submenu">
                      <span
                        class:list={[
                          'flex items-center justify-between px-4 py-2 text-sm transition-colors',
                          isItemActive(item) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
                        ]}
                      >
                        {item.label}
                        <svg class="h-3 w-3 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                      </span>
                      <div class="absolute left-full top-0 -ml-1 opacity-0 invisible group-hover/submenu:opacity-100 group-hover/submenu:visible transition-all z-10">
                        <div class="bg-white rounded-lg shadow-lg border border-warm-200 py-1 min-w-[160px]">
                          {item.menu.map((sub: { href?: string; label: string; menu?: { href: string; label: string }[] }) =>
                            sub.menu ? (
                              <div class="relative group/subsub">
                                <span
                                  class:list={[
                                    'flex items-center justify-between px-4 py-2 text-sm transition-colors whitespace-nowrap',
                                    isItemActive(sub) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
                                  ]}
                                >
                                  {sub.label}
                                  <svg class="h-3 w-3 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </span>
                                <div class="absolute left-full top-0 -ml-1 opacity-0 invisible group-hover/subsub:opacity-100 group-hover/subsub:visible transition-all z-20">
                                  <div class="bg-white rounded-lg shadow-lg border border-warm-200 py-1 min-w-[180px]">
                                    {sub.menu.map((leaf: { href: string; label: string }) => (
                                      <a
                                        href={leaf.href}
                                        class:list={[
                                          'block px-4 py-2 text-sm transition-colors whitespace-nowrap',
                                          isActive(leaf.href) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
                                        ]}
                                      >
                                        {leaf.label}
                                      </a>
                                    ))}
                                  </div>
                                </div>
                              </div>
                            ) : (
                              <a
                                href={sub.href!}
                                class:list={[
                                  'block px-4 py-2 text-sm transition-colors whitespace-nowrap',
                                  isActive(sub.href!) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
                                ]}
                              >
                                {sub.label}
                              </a>
                            )
                          )}
                        </div>
                      </div>
                    </div>
                  ) : (
                    <a
                      href={item.href}
                      class:list={[
                        'block px-4 py-2 text-sm transition-colors',
                        isItemActive(item) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
                      ]}
                    >
                      {item.label}
                    </a>
                  )
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
      </div>
    </div>

    <!-- Mobile hamburger -->
    <button
      type="button"
      id="nav-mobile-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-mobile-menu"
      class="md:hidden p-2 rounded-lg text-penn-blue hover:bg-penn-blue-light transition-colors"
    >
      <svg class="h-6 w-6 [.nav-open_&]:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg class="h-6 w-6 hidden [.nav-open_&]:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </nav>
</header>

<!-- Mobile menu overlay (outside header so it stacks above) -->
<div
  id="nav-mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  class="fixed inset-0 top-[57px] z-[60] md:hidden bg-white border-t border-warm-200 opacity-0 invisible transition-all duration-200 [.nav-open_&]:opacity-100 [.nav-open_&]:visible overscroll-contain overflow-y-auto"
>
    <div class="mx-auto max-w-5xl px-4 py-4 space-y-1">
      {programs.map((program) => (
        <div class="border-b border-warm-100 last:border-0 pb-3 last:pb-0">
          <p class="text-xs font-semibold uppercase tracking-wider text-warm-500 pt-2 first:pt-0 mb-2">{program.label}</p>
          <div class="space-y-0.5">
            {program.items.map((item) =>
              'menu' in item && item.menu ? (
                <details class="group/details">
                  <summary
                    class:list={[
                      'flex items-center justify-between list-none cursor-pointer py-2.5 px-3 rounded-lg text-sm font-medium transition-colors',
                      isItemActive(item) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
                    ]}
                  >
                    {item.label}
                    <svg class="h-4 w-4 transition-transform group-open/details:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </summary>
                  <div class="pl-4 mt-1 space-y-0.5">
                    {item.menu.map((sub: { href?: string; label: string; menu?: { href: string; label: string }[] }) =>
                      sub.menu ? (
                        <details class="group/sub">
                          <summary
                            class:list={[
                              'flex items-center justify-between list-none cursor-pointer py-2 px-3 rounded-lg text-sm transition-colors',
                              isItemActive(sub) ? 'text-penn-red bg-penn-red-light/70' : 'text-penn-blue hover:bg-penn-blue-light'
                            ]}
                          >
                            {sub.label}
                            <svg class="h-3.5 w-3.5 transition-transform group-open/sub:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                          </summary>
                          <div class="pl-2 mt-0.5 space-y-0.5">
                            {sub.menu.map((leaf: { href: string; label: string }) => (
                              <a
                                href={leaf.href}
                                class:list={[
                                  'block py-2 px-3 rounded-lg text-sm transition-colors',
                                  isActive(leaf.href) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
                                ]}
                              >
                                {leaf.label}
                              </a>
                            ))}
                          </div>
                        </details>
                      ) : (
                        <a
                          href={sub.href!}
                          class:list={[
                            'block py-2 px-3 rounded-lg text-sm transition-colors',
                            isActive(sub.href!) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
                          ]}
                        >
                          {sub.label}
                        </a>
                      )
                    )}
                  </div>
                </details>
              ) : (
                <a
                  href={item.href}
                  class:list={[
                    'block py-2.5 px-3 rounded-lg text-sm font-medium transition-colors',
                    isItemActive(item) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
                  ]}
                >
                  {item.label}
                </a>
              )
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

<script>
  const toggle = document.getElementById('nav-mobile-toggle');
  const menu = document.getElementById('nav-mobile-menu');
  if (toggle && menu) {
    const open = () => {
      document.documentElement.classList.add('nav-open');
      document.body.style.overflow = 'hidden';
      toggle?.setAttribute('aria-expanded', 'true');
      toggle?.setAttribute('aria-label', 'Close menu');
    };
    const close = () => {
      document.documentElement.classList.remove('nav-open');
      document.body.style.overflow = '';
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Open menu');
    };
    toggle.addEventListener('click', () => document.documentElement.classList.contains('nav-open') ? close() : open());
    menu.addEventListener('click', (e) => { if ((e.target as HTMLElement).closest('a')) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  }
</script>
