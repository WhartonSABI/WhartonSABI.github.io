---
const currentPath = Astro.url.pathname;

const programs = [
  {
    slug: 'seminar',
    label: 'Weekly Seminar',
    items: [
      { href: '/seminar/people', label: 'People' },
      { href: '/seminar/projects', label: 'Projects' },
      { href: '/seminar/data', label: 'Data' },
    ],
  },
  {
    slug: 'lab',
    label: 'Summer Lab',
    items: [
      { href: '/lab/people', label: 'People' },
      { href: '/lab/projects', label: 'Projects' },
      { href: '/lab/data', label: 'Data' },
    ],
  },
  {
    slug: 'moneyball',
    label: 'Moneyball Academy',
    items: [
      { href: '/moneyball', label: 'Home' },
      { href: '/moneyball/people', label: 'People' },
      { href: '/moneyball/projects', label: 'Projects' },
      { href: '/moneyball/data', label: 'Data' },
    ],
  },
];

const path = currentPath.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
  const h = href.replace(/\/$/, '');
  return path === h || (h !== '/' && path.startsWith(h + '/'));
}

function isItemActive(item: { href: string }): boolean {
  const h = item.href.replace(/\/$/, '');
  if (h === '/moneyball') return path === '/moneyball';
  return isActive(item.href);
}

function programIsActive(slug: string): boolean {
  return path === `/${slug}` || path.startsWith(`/${slug}/`);
}
---

<header class="border-b border-stone-200 bg-white/80 backdrop-blur-sm sticky top-0 z-50">
  <nav class="mx-auto max-w-5xl px-6 py-4 flex items-center gap-8">
    <a href="/" class="flex items-center gap-2 shrink-0">
      <img src="/images/wharton-logo.png" alt="" class="h-8 w-auto" />
      <span class="text-xl font-semibold text-penn-blue tracking-tight">WSABI</span>
    </a>

    <div class="flex gap-1">
      {programs.map((program) => (
        <div class="relative group">
          <button
            type="button"
            class:list={[
              'flex items-center gap-1 px-4 py-2 rounded-lg text-sm font-medium transition-colors',
              programIsActive(program.slug) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
            ]}
          >
            {program.label}
            <svg class="h-4 w-4 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute left-0 top-full pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
            <div class="bg-white rounded-lg shadow-lg border border-stone-200 py-1 min-w-[140px]">
              {program.items.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    'block px-4 py-2 text-sm transition-colors',
                    isItemActive(item) ? 'text-penn-red bg-penn-red-light' : 'text-penn-blue hover:bg-penn-blue-light'
                  ]}
                >
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </nav>
</header>
