---
interface ProjectLink {
  href: string;
  display: string;
}

interface Props {
  name: string;
  role: string;
  bio: string;
  image?: string | null;
  github?: string | null;
  projectLinks?: ProjectLink[];
}

const { name, role, bio, image, github, projectLinks = [] } = Astro.props;
const avatarUrl = image || (github ? `https://github.com/${github}.png` : null);
---

<article class="rounded-xl border border-stone-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
  <div class="flex gap-4">
    {avatarUrl ? (
      <img
        src={avatarUrl}
        alt={name}
        class="h-16 w-16 rounded-full object-cover shrink-0"
      />
    ) : (
      <div class="h-16 w-16 rounded-full bg-stone-200 flex items-center justify-center shrink-0">
        <span class="text-xl font-medium text-stone-500">{name.charAt(0)}</span>
      </div>
    )}
    <div class="min-w-0 flex-1">
      <h3 class="font-semibold text-stone-900">{name}</h3>
      <p class="text-sm text-stone-500 capitalize">{role}</p>
      <p class="mt-2 text-sm text-stone-600 leading-relaxed">{bio}</p>
      {projectLinks.length > 0 && (
        <p class="mt-2 text-xs">
          <span class="font-medium text-stone-500">Projects:</span>
          {projectLinks.map((link, i) => (
            <>
              {i > 0 && <span class="text-stone-400">, </span>}
              <a href={link.href} class="font-medium text-indigo-600 hover:text-indigo-700">{link.display}</a>
            </>
          ))}
        </p>
      )}
    </div>
  </div>
</article>
