---
interface ProjectLink {
  href: string;
  display: string;
}

interface Props {
  name: string;
  role: string;
  bio: string;
  image?: string | null;
  email?: string | null;
  github?: string | null;
  linkedin?: string | null;
  projectLinks?: ProjectLink[];
}

const { name, role, bio, image, email, github, linkedin, projectLinks = [] } = Astro.props;
const linkedinUrl = linkedin
  ? linkedin.startsWith('http')
    ? linkedin
    : `https://www.linkedin.com/in/${linkedin.replace(/\/$/, '')}/`
  : null;
const githubUrl = github
  ? github.startsWith('http')
    ? github
    : `https://github.com/${github.replace(/\/$/, '')}`
  : null;
// Avatar: explicit image first, then GitHub (LinkedIn has no public avatar URL).
const avatarUrl = image || (github ? `https://github.com/${github}.png` : null);
---

<article class="rounded-xl border border-stone-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
  <div class="flex gap-4">
    {avatarUrl ? (
      <img
        src={avatarUrl}
        alt={name}
        class="h-16 w-16 rounded-full object-cover shrink-0"
      />
    ) : (
      <div class="h-16 w-16 rounded-full bg-stone-200 flex items-center justify-center shrink-0">
        <span class="text-xl font-medium text-stone-500">{name.charAt(0)}</span>
      </div>
    )}
    <div class="min-w-0 flex-1">
      <h3 class="font-semibold text-penn-blue flex items-center gap-1.5">
        {name}
        {linkedinUrl && (
          <a
            href={linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-stone-500 hover:text-penn-red transition-colors"
            aria-label={`${name} on LinkedIn`}
          >
            <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        )}
        {githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-stone-500 hover:text-penn-red transition-colors"
            aria-label={`${name} on GitHub`}
          >
            <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
          </a>
        )}
      </h3>
      <p class="text-sm text-stone-600 capitalize">{role}</p>
      {bio && (
        <p class="mt-2 text-sm text-stone-600 leading-relaxed">{bio.replace(/, /g, ' · ').replace(/\.$/, '')}</p>
      )}
      {projectLinks.length > 0 && (
        <div class="mt-2 flex flex-wrap gap-1.5">
          {projectLinks.map((link) => (
            <a href={link.href} class="inline-flex rounded-lg bg-stone-100 px-2 py-0.5 text-xs font-medium text-penn-red transition-colors hover:bg-penn-red-light hover:text-penn-red">{link.display}</a>
          ))}
        </div>
      )}
      {email && (
        <p class="mt-2 text-xs">
          <a href={`mailto:${email}`} class="text-stone-600 hover:text-penn-blue">{email}</a>
        </p>
      )}
    </div>
  </div>
</article>
