---
interface Props {
  name: string;
  description: string;
  org: string;
  repo: string;
  preprint?: string;
  highlights?: string[];
  deliverables?: Array<{ label: string; path?: string; url?: string; icon?: 'article' | 'report' | 'presentation' }>;
}

const { name, description, org, repo, preprint, highlights = [], deliverables = [] } = Astro.props;
const repoUrl = `https://github.com/${org}/${repo}`;
const blobBase = `https://github.com/${org}/${repo}/blob/main/`;
// First link before Code: preprint if present, else first deliverable. Rest go after Code.
const beforeCode = preprint ?? deliverables[0];
const afterCode = preprint ? deliverables : deliverables.slice(1);
---

<article id={repo} class="rounded-xl border border-stone-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
  <div class="flex flex-col gap-4">
    <div>
      <h3 class="text-lg font-semibold text-penn-blue">{name}</h3>
      {highlights.length > 0 && (
        <p class="mt-2 text-sm font-medium text-penn-red">{highlights.join(' · ')}</p>
      )}
      <p class="mt-2 text-sm text-stone-600 leading-relaxed">{description}</p>
    </div>
    <div class="flex flex-wrap gap-2">
      {beforeCode && (
        (() => {
          const item = beforeCode;
          const isPreprint = typeof item === 'string';
          const href = isPreprint ? item : (item.url ?? `${blobBase}${(item.path ?? '').replace(/^\//, '')}`);
          if (isPreprint) {
            return (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-lg bg-penn-red-light px-3 py-1.5 text-sm font-medium text-penn-red transition-colors hover:bg-penn-red hover:text-white"
              >
                <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M3.8423 0a1.0037 1.0037 0 0 0-.922.6078c-.1536.3687-.0438.6275.2938 1.1113l6.9185 8.3597-1.0223 1.1058a1.0393 1.0393 0 0 0 .003 1.4229l1.2292 1.3135-5.4391 6.4444c-.2803.299-.4538.823-.2971 1.1986a1.0253 1.0253 0 0 0 .9585.635.9133.9133 0 0 0 .6891-.3405l5.783-6.126 7.4902 8.0051a.8527.8527 0 0 0 .6835.2597.9575.9575 0 0 0 .8777-.6138c.1577-.377-.017-.7502-.306-1.1407l-7.0518-8.3418 1.0632-1.13a.9626.9626 0 0 0 .0089-1.3165L4.6336.4639s-.3733-.4535-.768-.463zm0 .272h.0166c.2179.0052.4874.2715.5644.3639l.005.006.0052.0055 10.169 10.9905a.6915.6915 0 0 1-.0072.945l-1.0666 1.133-1.4982-1.7724-8.5994-10.39c-.3286-.472-.352-.6183-.2592-.841a.7307.7307 0 0 1 .6704-.4401Zm14.341 1.5701a.877.877 0 0 0-.6554.2418l-5.6962 6.1584 1.6944 1.8319 5.3089-6.5138c.3251-.4335.479-.6603.3247-1.0292a1.1205 1.1205 0 0 0-.9763-.689zm-7.6557 12.2823 1.3186 1.4135-5.7864 6.1295a.6494.6494 0 0 1-.4959.26.7516.7516 0 0 1-.706-.4669c-.1119-.2682.0359-.6864.2442-.9083l.0051-.0055.0047-.0055z"/></svg>
                arXiv
              </a>
            );
          }
          const d = item;
          return (
            <a
              href={d.url ?? `${blobBase}${(d.path ?? '').replace(/^\//, '')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded-lg bg-penn-red-light px-3 py-1.5 text-sm font-medium text-penn-red transition-colors hover:bg-penn-red hover:text-white"
            >
              {d.icon === 'report' ? (
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><path d="M8 18v-3"/><path d="M12 18v-5"/><path d="M16 18v-7"/></svg>
              ) : d.icon === 'presentation' ? (
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 4h18v14H3z"/><path d="M6 8h12"/><path d="M6 11h10"/><path d="M6 14h8"/></svg>
              ) : (
                <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
              )}
              {d.label}
            </a>
          );
        })()
      )}
      <a
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-lg bg-penn-blue-light px-3 py-1.5 text-sm font-medium text-penn-blue transition-colors hover:bg-penn-blue hover:text-white"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
        Code
      </a>
      {afterCode.map((d) => (
        <a
          href={d.url ?? `${blobBase}${(d.path ?? '').replace(/^\//, '')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-lg bg-penn-red-light px-3 py-1.5 text-sm font-medium text-penn-red transition-colors hover:bg-penn-red hover:text-white"
        >
          {d.icon === 'report' ? (
            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><path d="M8 18v-3"/><path d="M12 18v-5"/><path d="M16 18v-7"/></svg>
          ) : d.icon === 'presentation' ? (
            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 4h18v14H3z"/><path d="M6 8h12"/><path d="M6 11h10"/><path d="M6 14h8"/></svg>
          ) : (
            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          )}
          {d.label}
        </a>
      ))}
    </div>
  </div>
</article>
