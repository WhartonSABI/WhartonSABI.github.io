---
const { title = 'Wharton Sports Analytics App', description = 'Interactive sports analytics visualization.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <style is:global>
      :root {
        --ink: #0a203f;
        --ink-soft: #35527a;
        --accent: #b51f1f;
        --accent-soft: #f4dede;
        --bg-a: #f9f6f0;
        --bg-b: #e9eef8;
        --card: #ffffff;
        --muted: #5d6470;
        --line: #dce3ef;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100dvh;
        font-family: "Avenir Next", "Segoe UI", sans-serif;
        color: var(--ink);
        background:
          radial-gradient(1200px 600px at 90% -10%, #dde8fa 0%, transparent 60%),
          radial-gradient(900px 500px at -10% -10%, #f9e5df 0%, transparent 65%),
          linear-gradient(180deg, var(--bg-a), var(--bg-b));
      }

      .shell {
        width: min(1180px, 96vw);
        margin: 0 auto;
        padding: 1.2rem 0.6rem 2rem;
      }

      .hero {
        padding: 1.1rem 1rem 0.9rem;
      }

      .hero h1 {
        margin: 0;
        font-size: clamp(1.55rem, 2.2vw, 2.3rem);
        letter-spacing: -0.02em;
      }

      .hero p {
        margin: 0.45rem 0 0;
        color: var(--ink-soft);
        font-size: 0.95rem;
      }

      .app {
        background: color-mix(in oklab, var(--card) 90%, white);
        border: 1px solid var(--line);
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(9, 22, 51, 0.08);
        padding: 1rem;
      }

      .footer-note {
        color: var(--muted);
        font-size: 0.78rem;
        text-align: center;
        margin-top: 0.8rem;
      }

      @media (max-width: 760px) {
        .shell {
          width: min(98vw, 98vw);
          padding: 0.65rem 0.35rem 1rem;
        }

        .hero {
          padding: 0.6rem 0.45rem 0.75rem;
        }

        .app {
          border-radius: 14px;
          padding: 0.6rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <slot />
    </div>
  </body>
</html>
