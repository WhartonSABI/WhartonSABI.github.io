---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { loadRepos, type Project } from '../../lib/data';

const repos = loadRepos();
const config = repos.seminar;
const org = config.org;
---

<Layout title="Projects | Seminar" description="Featured work from seminar students.">
  <Nav />
  <main class="mx-auto max-w-5xl px-4 md:px-6 py-10 md:py-16">
    <h1 class="text-3xl font-bold text-penn-blue">Projects</h1>
    <p class="mt-2 text-warm-600">Featured work from seminar students.</p>

    <div class="mt-6 grid gap-6 sm:grid-cols-2">
      {config.projects.map((p: Project) => (
        <ProjectCard
          name={p.name}
          description={p.description}
          org={p.org_override || org}
          repo={p.repo}
          preprint={p.preprint}
          highlights={p.highlights}
          deliverables={p.deliverables}
        />
      ))}
    </div>
  </main>
</Layout>
