---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { loadRepos } from '../../lib/data';

const repos = loadRepos();
const programConfig = repos.seminar;
const projects = programConfig.projects.map((p) => ({
  ...p,
  program: 'Seminar',
  org: (p as { org_override?: string }).org_override || programConfig.org,
}));
---

<Layout title="Data" description="Data sources and repositories from WSABI projects.">
  <Nav />
  <main class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="text-3xl font-bold text-penn-blue">Data</h1>
    <p class="mt-2 text-stone-600">Data &amp; code links.</p>

    <div class="mt-12 space-y-4">
      {projects.map((p) => {
        const org = p.org;
        const dataUrl = `https://github.com/${org}/${p.repo}/tree/main/data`;
        const codeUrl = `https://github.com/${org}/${p.repo}`;
        return (
          <div class="rounded-xl border border-stone-200 bg-white p-5 shadow-sm">
            <h3 class="font-semibold text-penn-blue">{p.name}</h3>
            <p class="text-sm text-penn-blue-muted mt-0.5">{p.program}</p>
            <div class="mt-3 flex gap-3">
              <a href={dataUrl} target="_blank" rel="noopener" class="text-sm font-medium text-penn-red hover:underline">View data/</a>
              <a href={codeUrl} target="_blank" rel="noopener" class="text-sm font-medium text-penn-blue-muted hover:text-penn-red">View repo</a>
            </div>
          </div>
        );
      })}
    </div>
  </main>
</Layout>
