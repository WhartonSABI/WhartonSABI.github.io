---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { loadRepos } from '../../lib/data';

const repos = loadRepos();
const allProjects = [
  ...repos.seminar.projects.map((p) => ({ ...p, program: 'Seminar', org: (p as { org_override?: string }).org_override || repos.seminar.org })),
  ...repos.lab.projects.map((p) => ({ ...p, program: 'Lab', org: (p as { org_override?: string }).org_override || repos.lab.org })),
  ...repos.moneyball.projects.map((p) => ({ ...p, program: 'Moneyball', org: (p as { org_override?: string }).org_override || repos.moneyball.org })),
];
---

<Layout title="Data" description="Data sources and repositories from WSABI projects.">
  <Nav />
  <main class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="text-3xl font-bold text-stone-900">Data</h1>
    <p class="mt-2 text-stone-600">Links to data directories and code in our GitHub repositories.</p>

    <div class="mt-12 space-y-4">
      {allProjects.map((p) => {
        const org = p.org;
        const dataUrl = `https://github.com/${org}/${p.repo}/tree/main/data`;
        const codeUrl = `https://github.com/${org}/${p.repo}`;
        return (
          <div class="rounded-xl border border-stone-200 bg-white p-5 shadow-sm">
            <h3 class="font-semibold text-stone-900">{p.name}</h3>
            <p class="text-sm text-stone-500 mt-0.5">{p.program}</p>
            <div class="mt-3 flex gap-3">
              <a href={dataUrl} target="_blank" rel="noopener" class="text-sm font-medium text-indigo-600 hover:text-indigo-700">View data/</a>
              <a href={codeUrl} target="_blank" rel="noopener" class="text-sm font-medium text-stone-500 hover:text-stone-700">View repo</a>
            </div>
          </div>
        );
      })}
    </div>
  </main>
</Layout>
