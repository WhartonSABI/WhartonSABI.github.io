---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import PersonCard from '../../components/PersonCard.astro';
import { loadPeople, getProjectLink } from '../../lib/data';

const allConfigs = loadPeople();
const peopleConfigs = allConfigs.filter((c) => c.program === 'lab');
---

<Layout title="Summer Lab – People" description="Summer lab participants across the years.">
  <Nav />
  <main class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="text-3xl font-bold text-stone-900">Summer Lab</h1>
    <p class="mt-2 text-stone-600">Summer lab participants.</p>

    <div class="mt-12 space-y-4">
      {peopleConfigs.map((config, i) => {
        const yearLabel = String(config.year);
        return (
          <details class="group rounded-xl border border-stone-200 bg-white" {...(i === 0 ? { open: true } : {})}>
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-xl font-semibold text-stone-900 list-none [&::-webkit-details-marker]:hidden">
              {yearLabel}
              <svg class="h-5 w-5 shrink-0 text-stone-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="border-t border-stone-200 px-6 py-6">
              {config.instructors && config.instructors.length > 0 && (
                <div class="mb-8">
                  <h3 class="text-sm font-medium text-stone-500 uppercase tracking-wide mb-3">Instructors</h3>
                  <div class="grid gap-4 sm:grid-cols-2">
                {config.instructors.map((person) => {
                  const slugs = person.projects ?? (person.project ? [person.project] : []);
                  const projectLinks = slugs.map((s) => getProjectLink(s)).filter(Boolean) as { href: string; display: string }[];
                  return (
                    <PersonCard
                      name={person.name}
                      role={person.role}
                      bio={person.bio}
                      image={person.image}
                      github={person.github}
                      projectLinks={projectLinks}
                    />
                  );
                })}
                  </div>
                </div>
              )}
              {config.instructors && config.instructors.length > 0 && (
                <h3 class="text-sm font-medium text-stone-500 uppercase tracking-wide mb-3">Participants</h3>
              )}
              <div class="grid gap-4 sm:grid-cols-2">
                {config.people.map((person) => {
                  const slugs = person.projects ?? (person.project ? [person.project] : []);
                  const projectLinks = slugs.map((s) => getProjectLink(s)).filter(Boolean) as { href: string; display: string }[];
                  return (
                    <PersonCard
                      name={person.name}
                      role={person.role}
                      bio={person.bio}
                      image={person.image}
                      github={person.github}
                      projectLinks={projectLinks}
                    />
                  );
                })}
              </div>
            </div>
          </details>
        );
      })}
    </div>

    {peopleConfigs.length === 0 && (
      <p class="mt-12 text-stone-500">No roster data yet. Add YAML files in <code>src/config/people/</code> (e.g. <code>lab-2025.yaml</code>).</p>
    )}
  </main>
</Layout>
