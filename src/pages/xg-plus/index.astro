---
import LayoutServerQuality from '../../layouts/LayoutServerQuality.astro';

const dataUrl = `${import.meta.env.BASE_URL}xg-plus/data.json`;
const baseUrl = `${import.meta.env.BASE_URL}`;
---

<LayoutServerQuality
  title="xG+ Visualizer"
  description="Interactive trajectories across EPL seasons for teams and attackers."
>
  <header class="hero">
    <h1>xG+ Visualizer</h1>
    <p>Interactive trajectories across EPL seasons for teams and attackers.</p>
  </header>

  <main class="app">
    <div id="loading">Loading xG+ trajectory data...</div>

    <div id="app" class="sq-app" style="display:none;">
      <div class="controls-row">
        <div class="control-card">
          <div class="label">Group</div>
          <div class="sq-seg" id="mode-seg"></div>
        </div>
        <div class="control-card">
          <div class="label">Metric</div>
          <div class="sq-seg" id="metric-seg"></div>
        </div>
      </div>

      <div class="chart-wrap">
        <svg id="chart" viewBox="0 0 1020 460" aria-label="xG+ trajectory chart"></svg>
        <div class="sq-chart-footnote">Point size indicates chance volume.</div>
      </div>

      <div class="controls-grid">
        <div class="panel">
          <div class="panel-title">Visible <span id="group-label">Entities</span> (<span id="visible-count">0</span>/10)</div>
          <div class="sq-chip-row" id="selected-chips"></div>
          <div class="sq-sub-label">Presets</div>
          <div class="sq-btn-row">
            <button id="btn-top5" class="sq-btn">Top 5</button>
            <button id="btn-bottom5" class="sq-btn">Bottom 5</button>
            <button id="btn-risers" class="sq-btn">Biggest Risers</button>
            <button id="btn-fallers" class="sq-btn">Biggest Fallers</button>
            <button id="btn-random5" class="sq-btn">Random 5</button>
            <button id="btn-clear" class="sq-btn ghost">Clear All</button>
          </div>
        </div>

        <div class="panel">
          <div class="panel-title">Add <span id="group-label-add">Entities</span></div>
          <input id="entity-search" type="text" placeholder="Search..." class="search" />
          <div class="list" id="entity-list"></div>
        </div>
      </div>

      <div class="panel insights-panel">
        <div class="panel-title">Model Video Visualizations</div>
        <div id="gif-grid" class="gif-grid"></div>
      </div>
    </div>
  </main>

  <script define:vars={{ dataUrl, baseUrl }}>
    const palette = [
      '#0B3C5D', '#B51F1F', '#1E7A73', '#8A5A00', '#5D3A9B',
      '#B04670', '#2F5E1D', '#6B2E2E', '#0A6FAE', '#4E4E4E',
      '#A83A0E', '#1D4A8F',
    ];

    let DATA = null;
    const maxLines = 10;

    const state = {
      mode: 'teams',
      metric: 'teams_for_against',
      selected: new Set(),
      selectedPreset: 'top5',
      randomPresetKey: '',
      search: '',
    };

    const el = {
      loading: document.getElementById('loading'),
      app: document.getElementById('app'),
      modeSeg: document.getElementById('mode-seg'),
      metricSeg: document.getElementById('metric-seg'),
      chart: document.getElementById('chart'),
      visibleCount: document.getElementById('visible-count'),
      groupLabel: document.getElementById('group-label'),
      groupLabelAdd: document.getElementById('group-label-add'),
      selectedChips: document.getElementById('selected-chips'),
      top5: document.getElementById('btn-top5'),
      bottom5: document.getElementById('btn-bottom5'),
      random5: document.getElementById('btn-random5'),
      risers: document.getElementById('btn-risers'),
      fallers: document.getElementById('btn-fallers'),
      clear: document.getElementById('btn-clear'),
      search: document.getElementById('entity-search'),
      entityList: document.getElementById('entity-list'),
      gifGrid: document.getElementById('gif-grid'),
    };

    function currentGroup() {
      return DATA.modes[state.mode];
    }

    function setupSeg(container, options, value, onSelect) {
      container.innerHTML = '';
      options.forEach((o) => {
        const b = document.createElement('button');
        b.className = `sq-seg-btn ${o.value === value ? 'active' : ''}`;
        b.textContent = o.label;
        b.addEventListener('click', () => onSelect(o.value));
        container.appendChild(b);
      });
    }

    function selectionKey(names) {
      return [...new Set(names)].sort((a, b) => a.localeCompare(b)).join('|');
    }

    function recurringEntities() {
      return currentGroup().players.filter((p) => p.seasonsPresent >= 2);
    }

    function seriesMetricValue(point) {
      if (state.mode === 'teams') {
        if (state.metric === 'teams_diff') return point.diffRate ?? point.raw;
        return point.forRate ?? point.raw;
      }
      if (state.metric === 'attackers_goe') {
        const goals = Number.isFinite(point.goals) ? point.goals : 0;
        const expected = point.forRate ?? point.raw ?? 0;
        return goals - expected;
      }
      return point.forRate ?? point.raw;
    }

    function seriesMetricValueForPreset(point) {
      if (state.mode === 'teams') {
        return point.diffRate ?? point.raw;
      }
      return seriesMetricValue(point);
    }

    function latestEntityMetric(entity) {
      const sorted = [...(entity.series || [])].sort((a, b) => a.year - b.year);
      if (!sorted.length) return null;
      const latest = seriesMetricValueForPreset(sorted[sorted.length - 1]);
      return Number.isFinite(latest) ? latest : null;
    }

    function computePresetSets() {
      const recurring = recurringEntities();
      const scoredRecurring = recurring
        .map((p) => ({ name: p.name, score: latestEntityMetric(p), series: p.series }))
        .filter((p) => Number.isFinite(p.score));

      const top5 = [...scoredRecurring]
        .sort((a, b) => b.score - a.score)
        .slice(0, 5)
        .map((p) => p.name);
      const bottom5 = [...scoredRecurring]
        .sort((a, b) => a.score - b.score)
        .slice(0, 5)
        .map((p) => p.name);
      const biggestRisers = [...recurring]
        .map((p) => {
          if (!p.series || p.series.length < 2) return null;
          const sorted = [...p.series].sort((a, b) => a.year - b.year);
          const first = sorted[0];
          const last = sorted[sorted.length - 1];
          const firstVal = seriesMetricValueForPreset(first);
          const lastVal = seriesMetricValueForPreset(last);
          if (!Number.isFinite(firstVal) || !Number.isFinite(lastVal)) return null;
          const years = Math.max(1, last.year - first.year);
          return { name: p.name, slope: (lastVal - firstVal) / years };
        })
        .filter(Boolean)
        .sort((a, b) => b.slope - a.slope)
        .slice(0, 5)
        .map((p) => p.name);
      const biggestFallers = [...recurring]
        .map((p) => {
          if (!p.series || p.series.length < 2) return null;
          const sorted = [...p.series].sort((a, b) => a.year - b.year);
          const first = sorted[0];
          const last = sorted[sorted.length - 1];
          const firstVal = seriesMetricValueForPreset(first);
          const lastVal = seriesMetricValueForPreset(last);
          if (!Number.isFinite(firstVal) || !Number.isFinite(lastVal)) return null;
          const years = Math.max(1, last.year - first.year);
          return { name: p.name, slope: (lastVal - firstVal) / years };
        })
        .filter(Boolean)
        .sort((a, b) => a.slope - b.slope)
        .slice(0, 5)
        .map((p) => p.name);

      return { top5, bottom5, biggestRisers, biggestFallers };
    }

    function detectPreset() {
      const currentKey = selectionKey([...state.selected]);
      const preset = computePresetSets();
      if (currentKey === selectionKey(preset.top5)) return 'top5';
      if (currentKey === selectionKey(preset.bottom5)) return 'bottom5';
      if (currentKey === selectionKey(preset.biggestRisers)) return 'risers';
      if (currentKey === selectionKey(preset.biggestFallers)) return 'fallers';
      if (state.randomPresetKey && currentKey === state.randomPresetKey) return 'random5';
      return '';
    }

    function renderPresetButtons() {
      const map = {
        top5: el.top5,
        bottom5: el.bottom5,
        risers: el.risers,
        fallers: el.fallers,
        random5: el.random5,
      };
      Object.entries(map).forEach(([id, node]) => node.classList.toggle('active', id === state.selectedPreset));
    }

    function applySelection(names, presetId = '') {
      state.selected = new Set(names.slice(0, maxLines));
      state.selectedPreset = presetId;
      render();
    }

    function resetToTop5() {
      applySelection(computePresetSets().top5, 'top5');
    }

    function setBottom5() {
      applySelection(computePresetSets().bottom5, 'bottom5');
    }

    function setRandom5() {
      const candidates = [...recurringEntities()].map((p) => p.name);
      for (let i = candidates.length - 1; i > 0; i -= 1) {
        const j = Math.floor(Math.random() * (i + 1));
        [candidates[i], candidates[j]] = [candidates[j], candidates[i]];
      }
      const selection = candidates.slice(0, 5);
      state.randomPresetKey = selectionKey(selection);
      applySelection(selection, 'random5');
    }

    function setRisers(desc = true) {
      const preset = computePresetSets();
      applySelection(desc ? preset.biggestRisers : preset.biggestFallers, desc ? 'risers' : 'fallers');
    }

    function selectedEntities() {
      const byName = new Map(currentGroup().players.map((p) => [p.name, p]));
      return [...state.selected].map((n) => byName.get(n)).filter(Boolean);
    }

    function colorByName(entities) {
      const ordered = [...entities].sort((a, b) => a.name.localeCompare(b.name));
      const map = new Map();
      ordered.forEach((p, idx) => map.set(p.name, palette[idx % palette.length]));
      return map;
    }

    function alphaNameSort(a, b) {
      const an = (a?.name || '').trim().toLowerCase();
      const bn = (b?.name || '').trim().toLowerCase();
      return an.localeCompare(bn, undefined, { sensitivity: 'base' });
    }

    function ensureMetricValid() {
      if (state.mode === 'teams' && !['teams_for_against', 'teams_diff'].includes(state.metric)) {
        state.metric = 'teams_for_against';
      }
      if (state.mode === 'attackers' && !['attackers_for', 'attackers_goe'].includes(state.metric)) {
        state.metric = 'attackers_for';
      }
    }

    function metricValue(point) {
      return seriesMetricValue(point);
    }

    function pickNiceStep(target, candidates) {
      for (const c of candidates) {
        if (c >= target) return c;
      }
      return candidates[candidates.length - 1];
    }

    function buildTicks(minVal, maxVal) {
      const span = Math.max(1e-6, maxVal - minVal);
      const targetStep = span / 6;
      const steps = [0.1, 0.2, 0.5, 1, 2, 5, 10, 20, 50];
      const step = pickNiceStep(targetStep, steps);

      const tickMin = Math.floor(minVal / step) * step;
      const tickMax = Math.ceil(maxVal / step) * step;
      const ticks = [];
      for (let y = tickMin; y <= tickMax + step * 0.001; y += step) {
        ticks.push(Number(y.toFixed(6)));
      }
      return { ticks, step };
    }

    function formatTickValue(y, step) {
      const decimals = step >= 1 ? 0 : step >= 0.1 ? 1 : 2;
      return Number(y.toFixed(decimals)).toString();
    }

    function drawChart(entities) {
      const svg = el.chart;
      const W = 1020;
      const H = 460;
      const m = { t: 28, r: 28, b: 64, l: 76 };
      const iw = W - m.l - m.r;
      const ih = H - m.t - m.b;

      const points = entities.flatMap((p) => p.series.map((s) => ({ ...s, entity: p.name })));
      if (!points.length) {
        svg.innerHTML = `<text x="510" y="250" text-anchor="middle" fill="#5d6470" font-size="20">Add entities to draw trajectories</text>`;
        return;
      }

      const years = [...new Set(points.map((p) => p.year))].sort((a, b) => a - b);
      const seasonLabelByYear = new Map();
      points.forEach((p) => {
        if (!seasonLabelByYear.has(p.year)) seasonLabelByYear.set(p.year, p.season);
      });
      const xMin = years[0];
      const xMax = years[years.length - 1];
      const ys = points.flatMap((p) => {
        if (state.mode === 'teams' && state.metric === 'teams_for_against') {
          return [p.forRate, p.againstRate].filter((v) => Number.isFinite(v));
        }
        return [metricValue(p)];
      });
      let yMin = Math.min(...ys);
      let yMax = Math.max(...ys);
      const pad = (yMax - yMin || 1) * 0.08;
      yMin -= pad;
      yMax += pad;

      const { ticks, step } = buildTicks(yMin, yMax);
      const visibleTicks = ticks.filter((y) => y >= yMin - 1e-9 && y <= yMax + 1e-9);

      const sx = (x) => m.l + ((x - xMin) / Math.max(1, xMax - xMin)) * iw;
      const sy = (y) => m.t + (1 - ((y - yMin) / Math.max(1e-6, yMax - yMin))) * ih;

      const axis = [];
      for (const y of visibleTicks) {
        const py = sy(y);
        axis.push(`<line x1="${m.l}" y1="${py}" x2="${W - m.r}" y2="${py}" stroke="#e7ebf3" />`);
        axis.push(`<text x="${m.l - 10}" y="${py + 4}" text-anchor="end" fill="#4a5464" font-size="12">${formatTickValue(y, step)}</text>`);
      }

      const xAxis = years.map((yr) => {
        const full = seasonLabelByYear.get(yr) || String(yr);
        const short = full.includes('-') ? `${full.slice(2, 4)}-${full.slice(7, 9)}` : String(yr);
        return `<text x="${sx(yr)}" y="${H - m.b + 24}" text-anchor="middle" fill="#4a5464" font-size="12">${short}</text>`;
      });

      const colors = colorByName(entities);
      const lines = entities.map((p) => {
        const color = colors.get(p.name) || palette[0];
        const sorted = [...p.series].sort((a, b) => a.year - b.year);
        const rForShots = sorted.map((s) => Math.max(3, Math.min(11, 2 + Math.sqrt(Math.max(0, s.shots)) * 0.32)));

        if (state.mode === 'teams' && state.metric === 'teams_for_against') {
          const dFor = sorted.map((s, i) => `${i === 0 ? 'M' : 'L'} ${sx(s.year)} ${sy(s.forRate ?? 0)}`).join(' ');
          const dAgainst = sorted.map((s, i) => `${i === 0 ? 'M' : 'L'} ${sx(s.year)} ${sy(s.againstRate ?? 0)}`).join(' ');
          const circlesFor = sorted.map((s, i) => {
            const label = `${p.name} | ${s.season} | For ${(s.forRate ?? 0).toFixed(4)} | Chances ${s.shots}`;
            return `<circle cx="${sx(s.year)}" cy="${sy(s.forRate ?? 0)}" r="${rForShots[i]}" fill="${color}" opacity="0.9"><title>${label}</title></circle>`;
          }).join('');
          const circlesAgainst = sorted.map((s, i) => {
            const label = `${p.name} | ${s.season} | Against ${(s.againstRate ?? 0).toFixed(4)} | Chances ${s.shots}`;
            return `<circle cx="${sx(s.year)}" cy="${sy(s.againstRate ?? 0)}" r="${Math.max(2.6, rForShots[i] - 0.5)}" fill="${color}" opacity="0.75"><title>${label}</title></circle>`;
          }).join('');
          return `
            <path d="${dFor}" fill="none" stroke="${color}" stroke-width="2.5" stroke-linecap="round" />
            <path d="${dAgainst}" fill="none" stroke="${color}" stroke-width="2.2" stroke-dasharray="8 5" stroke-linecap="round" opacity="0.9" />
            ${circlesFor}
            ${circlesAgainst}
          `;
        }

        const d = sorted.map((s, i) => `${i === 0 ? 'M' : 'L'} ${sx(s.year)} ${sy(metricValue(s))}`).join(' ');
        const circles = sorted.map((s, i) => {
          const label = `${p.name} | ${s.season} | ${(metricValue(s)).toFixed(4)} | Chances ${s.shots}`;
          return `<circle cx="${sx(s.year)}" cy="${sy(metricValue(s))}" r="${rForShots[i]}" fill="${color}" opacity="0.9"><title>${label}</title></circle>`;
        }).join('');
        return `<path d="${d}" fill="none" stroke="${color}" stroke-width="2.5" stroke-linecap="round" />${circles}`;
      });

      svg.innerHTML = `
        <rect x="0" y="0" width="${W}" height="${H}" fill="#ffffff" rx="14" />
        ${axis.join('')}
        <line x1="${m.l}" y1="${H - m.b}" x2="${W - m.r}" y2="${H - m.b}" stroke="#bfc9db" />
        <line x1="${m.l}" y1="${m.t}" x2="${m.l}" y2="${H - m.b}" stroke="#bfc9db" />
        ${xAxis.join('')}
        ${lines.join('')}
      `;
    }

    function renderSelectedChips() {
      const players = selectedEntities()
        .sort(alphaNameSort);
      const colors = colorByName(players);
      el.visibleCount.textContent = String(players.length);
      el.selectedChips.innerHTML = '';

      players.forEach((p) => {
        const chip = document.createElement('button');
        chip.className = 'sq-chip';
        const color = colors.get(p.name) || palette[0];
        chip.style.borderColor = `${color}66`;
        chip.style.backgroundColor = `${color}22`;
        chip.style.color = color;
        chip.innerHTML = `<span class="sq-swatch" style="background:${color}"></span><span class="sq-chip-name">${p.name}</span><span class="sq-chip-x">×</span>`;
        chip.addEventListener('click', () => {
          state.selected.delete(p.name);
          render();
        });
        el.selectedChips.appendChild(chip);
      });
    }

    function renderEntityList() {
      const q = state.search.trim().toLowerCase();
      const rows = [...currentGroup().players]
        .sort((a, b) => a.name.localeCompare(b.name, undefined, { sensitivity: 'base' }))
        .filter((p) => !state.selected.has(p.name))
        .filter((p) => !q || p.name.toLowerCase().includes(q));

      el.entityList.innerHTML = '';
      rows.forEach((p) => {
        const row = document.createElement('div');
        row.className = 'player-row';

        const info = document.createElement('div');
        info.className = 'player-info';
        const teamsText = p.teams && p.teams.length ? ` · ${p.teams.slice(0, 2).join(', ')}${p.teams.length > 2 ? ' +' : ''}` : '';
        info.innerHTML = `<strong>${p.name}</strong><span>${p.seasonsPresent} seasons · ${p.totalShots} chances${teamsText}</span>`;

        const add = document.createElement('button');
        add.className = 'sq-add-btn';
        add.textContent = 'Add';
        add.disabled = state.selected.size >= maxLines;
        add.addEventListener('click', () => {
          if (state.selected.size >= maxLines) return;
          state.selected.add(p.name);
          render();
        });

        row.append(info, add);
        el.entityList.appendChild(row);
      });
    }

    function renderSegs() {
      setupSeg(el.modeSeg, [
        { value: 'teams', label: 'Teams' },
        { value: 'attackers', label: 'Attackers' },
      ], state.mode, (next) => {
        if (state.mode === next) return;
        state.mode = next;
        resetToTop5();
      });

      const metricOptions = state.mode === 'teams'
        ? [
            { value: 'teams_for_against', label: 'xG+ For/Against' },
            { value: 'teams_diff', label: 'xG+ Diff' },
          ]
        : [
            { value: 'attackers_for', label: 'xG+ For' },
            { value: 'attackers_goe', label: 'GoE+ (Goals - xG+)' },
          ];

      setupSeg(el.metricSeg, metricOptions, state.metric, (next) => {
        if (state.metric === next) return;
        state.metric = next;
        resetToTop5();
      });
    }

    function renderGroupLabels() {
      const label = currentGroup().label;
      el.groupLabel.textContent = label;
      el.groupLabelAdd.textContent = label;
    }

    function renderGifs() {
      el.gifGrid.innerHTML = '';
      (DATA.gifs || []).forEach((gif) => {
        const card = document.createElement('article');
        card.className = 'gif-card';
        card.innerHTML = `
          <img src="${baseUrl}${gif.src}" alt="${gif.file}" loading="lazy" />
          <p>${gif.caption}</p>
        `;
        el.gifGrid.appendChild(card);
      });
    }

    function render() {
      ensureMetricValid();
      state.selectedPreset = detectPreset();
      renderSegs();
      renderGroupLabels();
      renderPresetButtons();
      renderSelectedChips();
      renderEntityList();
      drawChart(selectedEntities());
    }

    el.top5.addEventListener('click', () => resetToTop5());
    el.bottom5.addEventListener('click', () => setBottom5());
    el.random5.addEventListener('click', () => setRandom5());
    el.risers.addEventListener('click', () => setRisers(true));
    el.fallers.addEventListener('click', () => setRisers(false));
    el.clear.addEventListener('click', () => {
      state.selected.clear();
      render();
    });
    el.search.addEventListener('input', () => {
      state.search = el.search.value || '';
      renderEntityList();
    });

    fetch(dataUrl, { cache: 'no-store' })
      .then((r) => r.json())
      .then((data) => {
        DATA = data;
        resetToTop5();
        renderGifs();
        el.loading.style.display = 'none';
        el.app.style.display = 'block';
      })
      .catch(() => {
        el.loading.textContent = 'Failed to load xG+ data.';
      });
  </script>

  <style is:global>
    #loading { text-align: center; color: #5d6470; padding: 3rem 1rem; font-size: 1rem; }
    .sq-app { --sq-font: "Avenir Next", "Segoe UI", sans-serif; font-family: var(--sq-font); font-size: 0.92rem; color: #132b4a; }
    .sq-app button, .sq-app input, .sq-app p, .sq-app span, .sq-app strong, .sq-app div { font-family: var(--sq-font); }
    .controls-row { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.75rem; }
    .control-card, .panel, .chart-wrap { border: 1px solid #dce3ef; border-radius: 14px; background: #fff; box-shadow: 0 8px 18px rgba(12, 35, 66, 0.06); }
    .control-card { padding: 0.72rem; }
    .chart-wrap { margin-top: 0.8rem; padding: 0.8rem; }
    .panel { padding: 0.7rem; }
    .label { color: #4d5768; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.01em; margin-bottom: 0.5rem; }
    .sq-seg { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .sq-seg-btn { border: 1px solid #cdd7e8; background: linear-gradient(180deg, #ffffff, #edf3ff); color: #10345d; border-radius: 999px; padding: 0.48rem 0.82rem; font-size: 0.8rem; font-weight: 700; cursor: pointer; }
    .sq-seg-btn.active { background: linear-gradient(180deg, #17457a, #12365e); color: #fff; border-color: #12365e; }
    #chart { width: 100%; height: auto; border-radius: 12px; border: 1px solid #eef1f7; background: #fff; }
    .sq-chart-footnote { margin-top: 0.38rem; font-size: 0.77rem; font-weight: 600; color: #5a667a; }
    .controls-grid { margin-top: 0.8rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
    .panel-title { font-size: 0.9rem; font-weight: 700; margin-bottom: 0.55rem; color: #122f54; }
    .sq-sub-label { margin-top: 0.72rem; margin-bottom: 0.42rem; font-size: 0.76rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: #5b6880; }
