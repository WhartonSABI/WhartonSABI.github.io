---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import AcademyContent from '../../../components/AcademyContent.astro';
import { loadAcademyPage, ACADEMY_PAGES } from '../../../lib/academy';

export function getStaticPaths() {
  return Object.keys(ACADEMY_PAGES)
    .filter((slug) => slug !== 'index')
    .map((slug) => ({
      params: { slug },
      props: { slug },
    }));
}

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/moneyball/academy/people');
const data = loadAcademyPage(slug);
if (!data) return Astro.redirect('/moneyball/academy/people');
---
<Layout title={`${data.title} | Moneyball Academy`} description="Moneyball Academy – R programming and data analysis.">
  <Nav />
  <main class="mx-auto max-w-4xl px-4 md:px-6 py-10 md:py-12">
    <AcademyContent content={data.content} />
  </main>
</Layout>
