---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import AcademyContent from '../../../components/AcademyContent.astro';
import { loadTcPage, TC_PAGES } from '../../../lib/academy';

export function getStaticPaths() {
  return Object.keys(TC_PAGES).map((slug) => ({
    params: { slug },
    props: { slug },
  }));
}

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/moneyball/training-camp/people');
const data = loadTcPage(slug);
if (!data) return Astro.redirect('/moneyball/training-camp/people');
---
<Layout title={`${data.title} | Training Camp`} description="Moneyball Training Camp – R programming and data analysis.">
  <Nav />
  <main class="mx-auto max-w-4xl px-4 md:px-6 py-10 md:py-12">
    <AcademyContent content={data.content} />
  </main>
</Layout>
