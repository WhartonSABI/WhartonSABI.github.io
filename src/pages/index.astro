---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="WSABI Research Hub" description="Weekly Seminar • Summer Lab • Moneyball Programs">
  <Nav />
  <main class="mx-auto max-w-5xl px-4 md:px-6 py-10 md:py-16">
    <section class="text-center mb-16">
      <h1 class="text-4xl font-bold text-penn-blue tracking-tight sm:text-5xl">
        WSABI Research Hub
      </h1>
      <p class="mt-6 text-lg text-stone-600 max-w-2xl mx-auto">
        Weekly Seminar • Summer Lab • Moneyball Programs
      </p>
    </section>

    <section class="space-y-16">
      <article class="border-b border-stone-200 pb-12 last:border-0 last:pb-0">
        <h2 class="text-2xl font-semibold text-penn-blue">Weekly Seminar</h2>
        <p class="mt-3 text-stone-600 leading-relaxed">
          Penn students and faculty meet weekly to discuss the state of sports analytics, introduce statistical methodology for solving applied problems, and collaborate on semester-long research projects. Research outputs include conference presentations, peer-reviewed publications, and public-facing articles. To learn more or get involved, contact <a href="mailto:jpipping@wharton.upenn.edu" class="text-penn-blue hover:underline" onclick="window.open(this.href, '_blank'); return false;">Jonathan Pipping-Gamón</a>.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          <a href="/seminar/people" class="inline-flex items-center rounded-lg bg-penn-red-light px-3 py-1.5 text-sm font-medium text-penn-red hover:bg-penn-red hover:text-white transition-colors">People</a>
          <a href="/seminar/projects" class="inline-flex items-center rounded-lg bg-penn-red-light px-3 py-1.5 text-sm font-medium text-penn-red hover:bg-penn-red hover:text-white transition-colors">Projects</a>
        </div>
      </article>

      <article class="border-b border-stone-200 pb-12 last:border-0 last:pb-0">
        <h2 class="text-2xl font-semibold text-penn-blue">Summer Lab</h2>
        <p class="mt-3 text-stone-600 leading-relaxed">
          A 9-week, paid summer program for Penn students interested in sports analytics and applied statistical research. Participants build a practical toolkit of statistical methods, sharpen their skills through daily labs, and complete a capstone project using real sports data. Past students have gone on to present their work at conferences, win research competitions, and publish in peer-reviewed journals. Applications are open now: <a href="https://wsb.wharton.upenn.edu/sports-analytics-research-lab/" target="_blank" rel="noopener noreferrer" class="text-penn-blue hover:underline">click here to apply</a>!
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          <a href="/lab/people" class="inline-flex items-center rounded-lg bg-penn-red-light px-3 py-1.5 text-sm font-medium text-penn-red hover:bg-penn-red hover:text-white transition-colors">People</a>
          <a href="/lab/projects" class="inline-flex items-center rounded-lg bg-penn-red-light px-3 py-1.5 text-sm font-medium text-penn-red hover:bg-penn-red hover:text-white transition-colors">Projects</a>
        </div>
      </article>

      <article class="border-b border-stone-200 pb-12 last:border-0 last:pb-0">
        <h2 class="text-2xl font-semibold text-penn-blue">Moneyball Programs</h2>
        <p class="mt-3 text-stone-600 leading-relaxed">
          An immersive introduction to statistics and sports analytics for high school students. Guided by Wharton faculty and researchers, students develop analytical and coding skills through hands-on work with real sports data, culminating in a final capstone project. Programs are offered in both on-campus and online formats. <a href="https://globalyouth.wharton.upenn.edu/application-information/" target="_blank" rel="noopener noreferrer" class="text-penn-blue hover:underline">Click here</a> to view course schedules and apply!
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          <a href="/moneyball/academy" class="inline-flex items-center rounded-lg bg-penn-red-light px-3 py-1.5 text-sm font-medium text-penn-red hover:bg-penn-red hover:text-white transition-colors">Academy</a>
          <a href="/moneyball/training-camp/lecture1" class="inline-flex items-center rounded-lg bg-penn-red-light px-3 py-1.5 text-sm font-medium text-penn-red hover:bg-penn-red hover:text-white transition-colors">Training Camp</a>
          <a href="/moneyball/projects" class="inline-flex items-center rounded-lg bg-penn-red-light px-3 py-1.5 text-sm font-medium text-penn-red hover:bg-penn-red hover:text-white transition-colors">Projects</a>
        </div>
      </article>
    </section>
  </main>
</Layout>
