---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { loadRepos } from '../lib/data';

const repos = loadRepos();
---

<Layout title="WSABI" description="Wharton Sports Analytics and Business Initiative – research seminar, summer lab, and Moneyball Academy.">
  <Nav />
  <main class="mx-auto max-w-5xl px-6 py-16">
    <section class="text-center mb-20">
      <h1 class="text-4xl font-bold text-stone-900 tracking-tight sm:text-5xl">
        Wharton Sports Analytics<br />& Business Initiative
      </h1>
      <p class="mt-6 text-lg text-stone-600 max-w-2xl mx-auto">
        Research, projects, and people from the undergraduate seminar, summer lab, and Moneyball Academy.
      </p>
    </section>

    <section class="grid sm:grid-cols-3 gap-8">
      <a href="/seminar/projects" class="group rounded-xl border border-stone-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-indigo-200">
        <h2 class="text-xl font-semibold text-stone-900 group-hover:text-indigo-600 transition-colors">Sports Research Seminar</h2>
        <p class="mt-2 text-stone-500">{repos.seminar.projects.length} projects</p>
        <p class="mt-4 text-sm text-stone-600">Undergraduate research projects in sports analytics.</p>
      </a>
      <a href="/lab/projects" class="group rounded-xl border border-stone-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-indigo-200">
        <h2 class="text-xl font-semibold text-stone-900 group-hover:text-indigo-600 transition-colors">Summer Lab</h2>
        <p class="mt-2 text-stone-500">{repos.lab.projects.length} projects</p>
        <p class="mt-4 text-sm text-stone-600">Intensive summer research with presentations and papers.</p>
      </a>
      <a href="/moneyball" class="group rounded-xl border border-stone-200 bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-indigo-200">
        <h2 class="text-xl font-semibold text-stone-900 group-hover:text-indigo-600 transition-colors">Moneyball Academy</h2>
        <p class="mt-2 text-stone-500">{repos.moneyball.projects.length} projects</p>
        <p class="mt-4 text-sm text-stone-600">High school summer program in sports statistics.</p>
      </a>
    </section>
  </main>
</Layout>
